/* 効果フローティングラベル群・トースト・各種告知ラベル・攻撃優先権演出。Main.uxml から読み込む。 */

.main-cost-warning-label {
    position: absolute;
    right: 32px;
    bottom: 304px;
    color: rgb(255, 80, 80);
    font-size: 20px;
    -unity-font-style: bold;
    -unity-text-outline-width: 1px;
    -unity-text-outline-color: rgba(0, 0, 0, 0.8);
    background-color: rgba(0, 0, 0, 0.55);
    padding-left: 12px;
    padding-right: 12px;
    padding-top: 6px;
    padding-bottom: 6px;
    border-top-left-radius: 6px;
    border-top-right-radius: 6px;
    border-bottom-left-radius: 6px;
    border-bottom-right-radius: 6px;
}

/* ─── トースト ──────────────────────────────────────────────────────── */

.main-toast-container {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 220px;
    align-items: center;
}

.main-toast-label {
    font-size: 22px;
    -unity-font-style: bold;
    color: rgb(255, 200, 80);
    background-color: rgba(10, 10, 20, 0.88);
    border-top-left-radius: 24px;
    border-top-right-radius: 24px;
    border-bottom-left-radius: 24px;
    border-bottom-right-radius: 24px;
    border-left-width: 1px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-color: rgba(255, 255, 255, 0.12);
    border-right-color: rgba(255, 255, 255, 0.12);
    border-top-color: rgba(255, 255, 255, 0.12);
    border-bottom-color: rgba(255, 255, 255, 0.12);
    padding-left: 28px;
    padding-right: 28px;
    padding-top: 12px;
    padding-bottom: 12px;
    -unity-text-outline-width: 1px;
    -unity-text-outline-color: rgba(0, 0, 0, 0.8);
}

/* ─── Evolve フローティングラベル ───────────────────────────────────────────── */
.evolve-label {
    font-size: 36px;
    -unity-font-style: bold;
    color: rgb(100, 220, 120);
    -unity-text-outline-width: 3px;
    -unity-text-outline-color: rgba(0, 0, 0, 0.9);
    -unity-text-align: middle-center;
    width: 200px;
    height: 60px;
}

/* ─── NextCardCostFree フローティングラベル（コスト0） ─────────────────────────── */
.cost-free-label {
    font-size: 36px;
    -unity-font-style: bold;
    color: rgb(255, 220, 100);
    -unity-text-outline-width: 3px;
    -unity-text-outline-color: rgba(0, 0, 0, 0.9);
    -unity-text-align: middle-center;
    width: 200px;
    height: 60px;
}

/* ─── ExtraTurn フローティングラベル（もう一度！） ───────────────────────────── */
.extra-turn-label {
    font-size: 40px;
    -unity-font-style: bold;
    color: rgb(255, 235, 130);
    -unity-text-outline-width: 3px;
    -unity-text-outline-color: rgba(0, 0, 0, 0.9);
    -unity-text-align: middle-center;
    width: 240px;
    height: 60px;
}

/* ─── BanishChar フローティングラベル ───────────────────────────────────────── */
